  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "npm run db:migrate:prod && node dist/server.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:prod": "node dist/db/migrate.js",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:prod": "node dist/db/seed.js",
    "create-admin": "tsx src/scripts/create-admin.ts",
    "create-admin:prod": "node dist/scripts/create-admin.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage",
    "test:debug": "cross-env NODE_ENV=test DEBUG_TESTS=true jest --runInBand"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
